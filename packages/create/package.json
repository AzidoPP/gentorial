{
  "name": "@gentorial/create",
  "version": "0.0.0",
  "description": "Project scaffolder for Gentorial courses.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "template"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "create-gentorial": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --sourcemap --clean && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config ../../vitest.config.ts --root ../.. packages/create/src",
    "pack:check": "pnpm pack --dry-run"
  },
  "keywords": [
    "create-gentorial",
    "gentorial",
    "scaffolding"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
